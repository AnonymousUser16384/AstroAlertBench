# Copy to ".env" in the repo root and fill in the keys you use.
# api_tinker.py, api_openai.py, api_anthropic.py, and api_google.py load .env via python-dotenv.

# --- Required per backend you actually call ---
# Tinker (Qwen / Kimi on Tinker): https://tinker-console.thinkingmachines.ai/
TINKER_API_KEY=

# OpenAI Responses API (api_openai.py)
OPENAI_API_KEY=

# Anthropic (api_anthropic.py; pip install anthropic if missing)
ANTHROPIC_API_KEY=

# Google Gemini (api_google.py)
GOOGLE_API_KEY=

# --- Optional paths & defaults ---
# Montage root dirname under the repo (default: stamps_llm_updated)
# ZTF_STAMPS_LLM_DIR=stamps_llm_updated

# Override default model ids without editing code:
# TINKER_MODEL=moonshotai/Kimi-K2.5
# OPENAI_MODEL=gpt-5.4
# OPENAI_REASONING_EFFORT=high
# ANTHROPIC_MODEL=claude-opus-4-7
# ANTHROPIC_REASONING_EFFORT=high
# GOOGLE_MODEL=gemini-2.5-pro
# GOOGLE_REASONING_EFFORT=high
